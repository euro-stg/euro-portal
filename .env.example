# ── Database ─────────────────────────────────────────────────────
# Gunakan nama service docker compose sebagai host (bukan localhost)
DATABASE_URL=postgresql://postgres:GANTI_PASSWORD_DB@euro_portal_db:5432/euro_portal?schema=public
POSTGRES_PASSWORD=GANTI_PASSWORD_DB

# ── NextAuth ──────────────────────────────────────────────────────
NEXTAUTH_URL=https://portal.euromedica.co.id
NEXTAUTH_SECRET=GANTI_SECRET_PANJANG_RANDOM

# Generate NEXTAUTH_SECRET:
#   openssl rand -base64 32

# ── Talenta API ───────────────────────────────────────────────────
TALENTA_BASE_URL=https://api.talenta.co
TALENTA_CLIENT_ID=
TALENTA_CLIENT_SECRET=

# ── SSO ───────────────────────────────────────────────────────────
SSO_SECRET=GANTI_SSO_SECRET
